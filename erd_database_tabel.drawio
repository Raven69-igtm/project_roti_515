        <mxCell id="t_prod" value="&lt;b&gt;PRODUK&lt;/b&gt;&lt;hr&gt;&lt;u&gt;id (PK)&lt;/u&gt;&lt;br&gt;nama&lt;br&gt;harga&lt;br&gt;stok&lt;br&gt;gambar" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="700" y="600" width="160" height="140" as="geometry" />
