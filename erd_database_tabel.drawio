        <!-- User to Pelanggan -->
        <mxCell id="l_u_p" edge="1" parent="1" source="t_user" target="t_pel" style="edgeStyle=orthogonalEdgeStyle;endArrow=ERmandOne;startArrow=ERmandOne;html=1;rounded=0;">
          <mxGeometry relative="1" as="geometry"/>
