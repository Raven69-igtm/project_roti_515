        <!-- Pelanggan to Order (1 to N) -->
        <mxCell id="l_p_o" edge="1" parent="1" source="t_pel" target="t_ord" style="edgeStyle=orthogonalEdgeStyle;endArrow=ERmany;startArrow=ERmandOne;html=1;rounded=0;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Order to Item Order (1 to N) -->
        <mxCell id="l_o_io" edge="1" parent="1" source="t_ord" target="t_io" style="edgeStyle=orthogonalEdgeStyle;endArrow=ERmany;startArrow=ERmandOne;html=1;rounded=0;">
