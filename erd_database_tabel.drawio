        <!-- Pelanggan to Keranjang -->
        <mxCell id="l_p_k" edge="1" parent="1" source="t_pel" target="t_ker" style="edgeStyle=orthogonalEdgeStyle;endArrow=ERzeroToOne;startArrow=ERmandOne;html=1;rounded=0;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Keranjang to Keranjang Item (1 to N) -->
        <mxCell id="l_k_ki" edge="1" parent="1" source="t_ker" target="t_ki" style="edgeStyle=orthogonalEdgeStyle;endArrow=ERmany;startArrow=ERmandOne;html=1;rounded=0;">
          <mxGeometry relative="1" as="geometry"/>
