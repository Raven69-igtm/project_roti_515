<mxfile version="21.6.8">
  <diagram id="erd_tables" name="ERD Database (Logical)">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ENTITIES (TABLES) -->
        <mxCell id="t_user" value="&lt;b&gt;USER&lt;/b&gt;&lt;hr&gt;&lt;u&gt;id (PK)&lt;/u&gt;&lt;br&gt;nama&lt;br&gt;email&lt;br&gt;password" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="400" y="50" width="160" height="120" as="geometry" />
