        <mxCell id="t_jad" value="&lt;b&gt;JADWAL_AMBIL&lt;/b&gt;&lt;hr&gt;&lt;u&gt;id (PK)&lt;/u&gt;&lt;br&gt;jam_mulai&lt;br&gt;jam_selesai&lt;br&gt;is_aktif" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
