        <mxCell id="t_admin" value="&lt;b&gt;ADMIN&lt;/b&gt;&lt;hr&gt;&lt;u&gt;user_id (PK, FK)&lt;/u&gt;&lt;br&gt;level" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="150" y="200" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="t_pel" value="&lt;b&gt;PELANGGAN&lt;/b&gt;&lt;hr&gt;&lt;u&gt;user_id (PK, FK)&lt;/u&gt;&lt;br&gt;no_hp&lt;br&gt;tgl_daftar" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="400" y="250" width="160" height="100" as="geometry" />
        </mxCell>

        <mxCell id="t_ker" value="&lt;b&gt;KERANJANG&lt;/b&gt;&lt;hr&gt;&lt;u&gt;id (PK)&lt;/u&gt;&lt;br&gt;pelanggan_id (FK)" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="700" y="250" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="t_ki" value="&lt;b&gt;KERANJANG_ITEM&lt;/b&gt;&lt;hr&gt;&lt;u&gt;keranjang_id (PK, FK)&lt;/u&gt;&lt;br&gt;&lt;u&gt;produk_id (PK, FK)&lt;/u&gt;&lt;br&gt;qty" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="700" y="400" width="180" height="100" as="geometry" />
        </mxCell>

        <mxCell id="t_ord" value="&lt;b&gt;ORDER&lt;/b&gt;&lt;hr&gt;&lt;u&gt;id (PK)&lt;/u&gt;&lt;br&gt;pelanggan_id (FK)&lt;br&gt;status&lt;br&gt;total&lt;br&gt;jam_ambil&lt;br&gt;metode_bayar" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="400" y="450" width="180" height="160" as="geometry" />
