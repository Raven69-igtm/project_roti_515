        <mxCell id="t_io" value="&lt;b&gt;ITEM_ORDER&lt;/b&gt;&lt;hr&gt;&lt;u&gt;order_id (PK, FK)&lt;/u&gt;&lt;br&gt;&lt;u&gt;produk_id (PK, FK)&lt;/u&gt;&lt;br&gt;qty&lt;br&gt;harga_satuan" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=10;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="400" y="700" width="180" height="120" as="geometry" />
